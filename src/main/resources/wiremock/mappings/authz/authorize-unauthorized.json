{
  "priority": 8,
  "request": {
    "method": "POST",
    "urlPattern": "/authz/authorize",
    "headers": {
      "Authorization": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 401,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
