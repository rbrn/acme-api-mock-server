{
  "priority": 2,
  "request": {
    "method": "POST",
    "urlPathPattern": "/advisory-appointments/.*",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "X-BFA-Client": {
        "absent": true
      }
    }
  },
  "response": {
    "status": 403,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "mobile.api/advisory-appointments/errors/invalid-client.json"
  }
}
