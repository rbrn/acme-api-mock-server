{
  "priority": 5,
  "request": {
    "method": "GET",
    "urlPath": "/advisory-appointments/eligibility",
    "headers": {
      "Authorization": {
        "matches": "Bearer .+"
      },
      "X-BFA-Client": {
        "equalTo": "advisory-appointment-bff"
      },
      "X-Correlation-ID": {
        "matches": ".+"
      }
    },
    "queryParameters": {
      "consultationChannel": {
        "equalTo": "BRANCH"
      },
      "city": {
        "matches": "(?i).*berlin.*"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "bodyFileName": "mobile.api/advisory-appointments/eligibility/branch-berlin.json"
  }
}
